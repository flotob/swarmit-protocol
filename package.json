{
  "name": "swarmit-protocol",
  "version": "0.4.0",
  "description": "Shared JavaScript implementation of the Swarmit (Swarm Message Board v1) protocol: object builders, validators, reference helpers, SwarmitRegistryV2 ABI and calldata encoders, and an optional Node Bee client. Consumed by swarmit (Vue web app), swarmit-curator, swarmit-dashboard, and swarmit-bot.",
  "type": "module",
  "files": [
    "src",
    "README.md",
    "package.json"
  ],
  "exports": {
    ".": "./src/index.js",
    "./objects": "./src/objects/index.js",
    "./references": "./src/references.js",
    "./names": "./src/names.js",
    "./usernames": "./src/usernames.js",
    "./username-registry": "./src/username-registry/index.js",
    "./chain": "./src/chain/index.js",
    "./swarm": "./src/swarm/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "node --test 'test/**/*.test.js'"
  },
  "dependencies": {
    "ethers": "^6.13.0"
  },
  "peerDependencies": {
    "@ethersphere/bee-js": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "@ethersphere/bee-js": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "swarmit",
    "swarm",
    "ethereum",
    "gnosis",
    "protocol"
  ],
  "license": "MIT"
}
